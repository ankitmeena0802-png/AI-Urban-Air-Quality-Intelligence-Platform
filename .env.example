# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# GOOGLE_MAPS_API_KEY: Required for interactive Google Maps (or GOOGLE_MAPS_PLATFORM_KEY)
GOOGLE_MAPS_API_KEY="MY_GOOGLE_MAPS_KEY"

# WEATHER_API_KEY: Optional custom Weather API key (defaults to free real-time Open-Meteo)
WEATHER_API_KEY=

# AIR_QUALITY_API_KEY: Optional custom AQI API key (defaults to free real-time Open-Meteo)
AIR_QUALITY_API_KEY=
